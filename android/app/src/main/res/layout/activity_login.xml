<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header Space -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- App Logo Icon / Shield Badge -->
        <FrameLayout
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:background="@android:drawable/dialog_holo_dark_frame"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🛡️"
                android:textSize="42sp" />
        </FrameLayout>

        <!-- Title and description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FÚTBOL RÁPIDO TRIBOL"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel Administrativo de Control"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <!-- Connection Badge with pulsing animation representation -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/card_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2D3748">

            <View
                android:id="@+id/pulse_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/success_green"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscando servidor..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card Container containing Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:background="@android:drawable/edit_text"
                android:backgroundTint="@color/border_color"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:background="@android:drawable/edit_text"
                android:backgroundTint="@color/border_color"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Login Action Button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Ingresar al Sistema"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:backgroundTint="@color/colorAccent" />

        </LinearLayout>

        <!-- Demo auto-complete trigger button -->
        <Button
            android:id="@+id/btn_demo_autofill"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Auto-completar Credenciales de Demostración"
            android:textColor="@color/colorAccent"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:layout_marginBottom="24dp" />

        <!-- Advanced Server URL Switcher Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔧 CONFIGURACIÓN DE RED"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:inputType="textUri"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:background="@android:drawable/edit_text"
                android:backgroundTint="@color/border_color"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:text="https://ais-dev-trmfkkvl4di76jnrnkwfg6-270141958746.us-west2.run.app" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="* Modifica para apuntar al localhost emulador (http://10.0.2.2:3000) o a tu propio servidor."
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btn_save_url"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Guardar y Probar"
                android:textSize="10sp"
                android:layout_marginTop="8dp"
                android:layout_gravity="right"
                android:textAllCaps="false"
                android:backgroundTint="@color/border_color"
                android:textColor="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
