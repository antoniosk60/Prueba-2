<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Client and price row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_client_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cliente Cargando..."
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_alignParentLeft="true" />

        <TextView
            android:id="@+id/tv_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0 MXN"
            android:textColor="@color/success_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_alignParentRight="true" />
    </RelativeLayout>

    <!-- Details -->
    <TextView
        android:id="@+id/tv_court_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancha"
        android:textColor="@color/colorAccent"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_date_timeslot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fecha y hora"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_color"
        android:layout_marginBottom="12dp" />

    <!-- Badges Row & action button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="36dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="4dp"
                android:layout_marginRight="6dp" />

            <TextView
                android:id="@+id/tv_payment_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Pagado"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_manage_reservation"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="Gestionar"
            android:textSize="10dp"
            android:textAllCaps="false"
            android:paddingHorizontal="10dp"
            android:backgroundTint="@color/border_color"
            android:textColor="@color/text_primary" />

    </RelativeLayout>

</LinearLayout>
