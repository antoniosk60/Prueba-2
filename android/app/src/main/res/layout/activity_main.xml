<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Top Administration Navbar -->
    <RelativeLayout
        android:id="@+id/top_navbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/card_background"
        android:paddingHorizontal="16dp"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRIBOL ADMIN"
                android:textColor="@color/colorAccent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_admin_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="admin@canchafutbol.com"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_logout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_lock_power_off"
            android:contentDescription="Logout"
            android:tooltipText="Cerrar Sesión" />
    </RelativeLayout>

    <!-- Cloud Synchronization Activity Bar -->
    <LinearLayout
        android:id="@+id/cloud_status_bar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_below="@id/top_navbar"
        android:background="#064E3B"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/success_green"
            android:layout_marginRight="6dp" />

        <TextView
            android:id="@+id/tv_firebase_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sincronizado con Firestore en Tiempo Real"
            android:textColor="#D1FAE5"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Views Frame Container -->
    <FrameLayout
        android:id="@+id/views_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_navigation"
        android:layout_below="@id/cloud_status_bar">

        <!-- TAB 1: DASHBOARD VIEW -->
        <ScrollView
            android:id="@+id/view_dashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumen General del Complejo"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Grid-like Bento Stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="16dp">

                    <!-- Card 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/card_background"
                        android:padding="12dp"
                        android:layout_marginRight="6dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reservas"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_reservations"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Card 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/card_background"
                        android:padding="12dp"
                        android:layout_marginHorizontal="3dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Equipos"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_teams"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Card 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/card_background"
                        android:padding="12dp"
                        android:layout_marginLeft="6dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ingresos Est."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_stat_revenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0"
                            android:textColor="@color/success_green"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Shortcut Panel Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Acceso Rápido"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/btn_shortcut_reservations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🗓️ Ver Lista de Reservaciones"
                        android:textAllCaps="false"
                        android:layout_marginBottom="8dp"
                        android:backgroundTint="@color/border_color"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_shortcut_add_team"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏆 Crear Nuevo Equipo"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/border_color"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <!-- Interactive Info Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Promociones Activas"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_promos_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cargando promociones..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- TAB 2: RESERVATIONS VIEW -->
        <LinearLayout
            android:id="@+id/view_reservations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Control de Reservas"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Search box -->
            <EditText
                android:id="@+id/et_search_reservations"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/card_background"
                android:hint="Buscar por cliente o cancha..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Swipe/Refresh indication or Loading Status -->
            <TextView
                android:id="@+id/tv_reservations_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descargando registros..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- RecyclerView of reservation cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_reservations"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- TAB 3: TEAMS VIEW -->
        <ScrollView
            android:id="@+id/view_teams"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipos del Torneo"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Add Team form -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕ REGISTRAR NUEVO EQUIPO"
                        android:textColor="@color/colorAccent"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/et_new_team_name"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="Nombre del Equipo"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:background="@android:drawable/edit_text"
                        android:backgroundTint="@color/border_color"
                        android:paddingHorizontal="10dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/et_new_team_captain"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="Capitán (Nombre)"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:background="@android:drawable/edit_text"
                        android:backgroundTint="@color/border_color"
                        android:paddingHorizontal="10dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/et_new_team_division"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="División (Ej: Primera Fuerza)"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:background="@android:drawable/edit_text"
                        android:backgroundTint="@color/border_color"
                        android:paddingHorizontal="10dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="14dp" />

                    <Button
                        android:id="@+id/btn_create_team"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="Inscribir Equipo"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/colorAccent"
                        android:textColor="@color/white" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equipos Inscritos"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_teams"
                    android:layout_width="match_parent"
                    android:layout_height="350dp" />

            </LinearLayout>
        </ScrollView>

        <!-- TAB 4: FIELDS/PRICES VIEW -->
        <ScrollView
            android:id="@+id/view_fields"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tarifas de Canchas"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Cancha 1 Form Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_court_title_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancha 1 (Fútbol Estándar)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp"
                            android:layout_marginRight="4dp" />

                        <EditText
                            android:id="@+id/et_court_rate_1"
                            android:layout_width="100dp"
                            android:layout_height="40dp"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:background="@android:drawable/edit_text"
                            android:backgroundTint="@color/border_color"
                            android:paddingHorizontal="10dp"
                            android:text="600" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" pesos / hora"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginLeft="6dp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_update_court_1"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_gravity="right"
                        android:layout_marginTop="10dp"
                        android:text="Guardar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/colorAccent" />
                </LinearLayout>

                <!-- Cancha 2 Form Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_court_title_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancha 2 (Fútbol Uruguayo / Pro)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp"
                            android:layout_marginRight="4dp" />

                        <EditText
                            android:id="@+id/et_court_rate_2"
                            android:layout_width="100dp"
                            android:layout_height="40dp"
                            android:inputType="number"
                            android:textColor="@color/text_primary"
                            android:background="@android:drawable/edit_text"
                            android:backgroundTint="@color/border_color"
                            android:paddingHorizontal="10dp"
                            android:text="800" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" pesos / hora"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginLeft="6dp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_update_court_2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_gravity="right"
                        android:layout_marginTop="10dp"
                        android:text="Guardar"
                        android:textSize="11sp"
                        android:backgroundTint="@color/colorAccent" />
                </LinearLayout>

                <!-- Dynamic pricing note -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/card_background"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Sincronización de Reglas de Precios"
                        android:textColor="@color/warning_orange"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Los cambios de tarifas guardados se propagarán inmediatamente en el panel administrativo del servidor en tiempo real y serán visibles para todos sus clientes finales."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Bottom Navigation Anchored Component -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@color/card_background"
        app:itemIconTint="@color/colorAccent"
        app:itemTextColor="@color/text_primary"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>
