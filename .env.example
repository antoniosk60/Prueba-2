# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this with the Cloud Run service URL.
APP_URL=

# TWILIO_ACCOUNT_SID: Your Twilio Account SID for sending WhatsApp messages.
TWILIO_ACCOUNT_SID=

# TWILIO_AUTH_TOKEN: Your Twilio Auth Token.
TWILIO_AUTH_TOKEN=

# TWILIO_WHATSAPP_NUMBER: Your Twilio WhatsApp sender number (sandbox or approved number).
# Default sandbox number: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ADMIN_WHATSAPP_NUMBER: Administrator's WhatsApp phone number to receive automatic booking confirmation notifications.
# E.g. +525512345678
ADMIN_WHATSAPP_NUMBER=

# EMAIL_FROM: The sender identity name and address for booking confirmations
EMAIL_FROM=Guerreros Ayotla <comprobantes@canchafutbol.com>

# RESEND_API_KEY: Standard Resend key starting with re_
RESEND_API_KEY=

# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS: Optional SMTP fallback parameters
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

